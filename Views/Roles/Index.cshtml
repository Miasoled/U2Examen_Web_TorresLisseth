@model List<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Roles del sistema";
}

<h2>Roles del sistema</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info">@TempData["Info"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre del rol</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.Name</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="AssignRole" class="btn btn-primary">Asignar rol a usuario</a>
<a asp-action="UserRoles" class="btn btn-secondary ms-2">Ver usuarios y roles</a>
