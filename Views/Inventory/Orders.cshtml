@model IEnumerable<NorthwindApp.Models.Order>

@{
    ViewData["Title"] = "rdenes Registradas";
}

<h2> rdenes Registradas</h2>

<a asp-action="Index" class="btn btn-secondary mb-3"> Volver al Inventario</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Orden #</th>
            <th>Cliente</th>
            <th>Fecha</th>
            <th>Ciudad</th>
            <th>Pas</th>
            <th>Detalle</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderId</td>
                <td>@order.ShipName</td>
                <td>@order.OrderDate?.ToString("dd/MM/yyyy")</td>
                <td>@order.ShipCity</td>
                <td>@order.ShipCountry</td>
                <td>
                    <a asp-action="OrderDetails" asp-route-id="@order.OrderId"
                       class="btn btn-info btn-sm">Ver Detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>
