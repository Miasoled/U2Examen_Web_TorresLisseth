@model NorthwindApp.Models.Order

@{
    ViewData["Title"] = "Orden Confirmada";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<h2> Orden #@Model.OrderId Registrada Exitosamente</h2>
<p>Fecha: <strong>@Model.OrderDate</strong></p>
<p>Destino: <strong>@Model.ShipCity, @Model.ShipCountry</strong></p>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Producto</th>
            <th class="text-end">Precio Unitario</th>
            <th class="text-center">Cantidad</th>
            <th class="text-end">Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detail in Model.OrderDetails)
        {
            <tr>
                <td>@detail.Product.ProductName</td>
                <td class="text-end">$@detail.UnitPrice.ToString("0.00")</td>
                <td class="text-center">@detail.Quantity</td>
                <td class="text-end">$@((detail.UnitPrice * detail.Quantity).ToString("0.00"))</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-success fw-bold">
            <td colspan="3" class="text-end">TOTAL</td>
            <td class="text-end">
                $@Model.OrderDetails.Sum(d => d.UnitPrice * d.Quantity).ToString("F2")
            </td>
        </tr>
    </tfoot>
</table>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-primary"> Seguir comprando</a>
</div>
