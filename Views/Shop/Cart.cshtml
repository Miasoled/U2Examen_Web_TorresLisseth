@model List<NorthwindApp.Models.CartItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<h2> Mi Carrito de Compras</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">Tu carrito est vaco.</div>
    <a asp-action="Index" class="btn btn-primary"> Volver a la tienda</a>
}
else
{
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th class="text-end">Precio Unitario</th>
                <th class="text-center">Cantidad</th>
                <th class="text-end">Subtotal</th>
                <th class="text-center">Accin</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td class="text-end">$@item.UnitPrice.ToString("0.00")</td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end">$@item.Subtotal.ToString("0.00")</td>
                    <td class="text-center">
                        <form method="post" asp-action="RemoveFromCart">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-danger btn-sm"> Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success fw-bold">
                <td colspan="3" class="text-end">TOTAL</td>
                <td class="text-end">$@Model.Sum(i => i.Subtotal).ToString("F2")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="mt-3 d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary"> Seguir comprando</a>
        <a asp-action="Checkout" class="btn btn-success btn-lg"> Confirmar Compra</a>
    </div>
}
